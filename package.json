{
  "name": "side-chick",
  "displayName": "Side Bae",
  "version": "0.1.0",
  "description": "AI-powered codebase onboarding via guided code tours",
  "publisher": "side-bae",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/side-bae.git"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "side-chick",
          "title": "Side Bae",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "side-chick": [
        {
          "id": "sideChick.featureTree",
          "name": "Features",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "sideChick.generateTour",
        "title": "Ask About a Feature",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.startTour",
        "title": "Start Saved Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.nextEdge",
        "title": "Follow Path",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.previousNode",
        "title": "Go Back",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.goForward",
        "title": "Go Forward",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.stopTour",
        "title": "Stop Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.refreshFeatures",
        "title": "Refresh Features",
        "category": "Side Bae",
        "icon": "$(refresh)"
      },
      {
        "command": "sideChick.discoverFeatures",
        "title": "Scan Codebase for Features",
        "category": "Side Bae",
        "icon": "$(search)"
      },
      {
        "command": "sideChick.openTour",
        "title": "Open Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideChick.whatsNew",
        "title": "What's New",
        "category": "Side Bae",
        "icon": "$(history)"
      },
      {
        "command": "sideChick.investigateIssue",
        "title": "Investigate Issue",
        "category": "Side Bae",
        "icon": "$(search-fuzzy)"
      }
    ],
    "keybindings": [
      {
        "command": "sideChick.previousNode",
        "key": "alt+left",
        "when": "sideChick.tourActive"
      },
      {
        "command": "sideChick.goForward",
        "key": "alt+right",
        "when": "sideChick.tourActive"
      },
      {
        "command": "sideChick.nextEdge",
        "key": "alt+down",
        "when": "sideChick.tourActive"
      },
      {
        "command": "sideChick.stopTour",
        "key": "escape",
        "when": "sideChick.tourActive && !editorHasSelection && !findInputFocussed && !inQuickOpen"
      },
      {
        "command": "sideChick.generateTour",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sideChick.refreshFeatures",
          "when": "view == sideChick.featureTree",
          "group": "navigation"
        },
        {
          "command": "sideChick.discoverFeatures",
          "when": "view == sideChick.featureTree",
          "group": "navigation"
        },
        {
          "command": "sideChick.whatsNew",
          "when": "view == sideChick.featureTree",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "sideChick.nextEdge",
          "when": "sideChick.tourActive"
        },
        {
          "command": "sideChick.previousNode",
          "when": "sideChick.tourActive"
        },
        {
          "command": "sideChick.goForward",
          "when": "sideChick.tourActive"
        },
        {
          "command": "sideChick.stopTour",
          "when": "sideChick.tourActive"
        },
        {
          "command": "sideChick.openTour",
          "when": "false"
        },
        {
          "command": "sideChick.refreshFeatures",
          "when": "false"
        },
        {
          "command": "sideChick.discoverFeatures",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Side Bae",
      "properties": {
        "sideChick.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the Claude CLI binary. Leave empty to auto-detect. Set this if the extension can't find Claude (run `which claude` in your terminal to find the path)."
        },
        "sideChick.model": {
          "type": "string",
          "default": "haiku",
          "description": "Claude model for tour generation (haiku = fast, sonnet = balanced, opus = thorough)"
        },
        "sideChick.maxBudgetUsd": {
          "type": "number",
          "default": 0.5,
          "description": "Max cost (USD) per tour or feature scan"
        },
        "sideChick.celebrations": {
          "type": "string",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Follow system preference (respects Reduce Motion)",
            "Always show confetti and animations",
            "Never show confetti or animations"
          ],
          "description": "Control confetti and celebration animations"
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "sideChick.featureTree",
        "contents": "Open a folder to start exploring with Side Bae.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      },
      {
        "view": "sideChick.featureTree",
        "contents": "Understand this codebase with AI-guided walkthroughs.\n[Ask About a Feature](command:sideChick.generateTour)\n[Discover All Features](command:sideChick.discoverFeatures)",
        "when": "workbenchState != empty && !sideChick.hasTours && !sideChick.featuresLoaded"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "oxlint": "latest",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84"
  }
}
