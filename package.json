{
  "name": "side-bae",
  "displayName": "Side Bae",
  "version": "0.3.0-beta.2",
  "description": "AI-powered codebase onboarding via guided code tours",
  "publisher": "side-bae",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/side-bae.git"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "side-bae",
          "title": "Side Bae",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "side-bae": [
        {
          "id": "sideBae.featureTree",
          "name": "Features",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "sideBae.generateTour",
        "title": "Ask About a Feature",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.startTour",
        "title": "Start Saved Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.nextEdge",
        "title": "Follow Path",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.previousNode",
        "title": "Go Back",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.goForward",
        "title": "Go Forward",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.stopTour",
        "title": "Stop Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.refreshFeatures",
        "title": "Refresh Features",
        "category": "Side Bae",
        "icon": "$(refresh)"
      },
      {
        "command": "sideBae.discoverFeatures",
        "title": "Scan Codebase for Features",
        "category": "Side Bae",
        "icon": "$(search)"
      },
      {
        "command": "sideBae.openTour",
        "title": "Open Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.whatsNew",
        "title": "What's New",
        "category": "Side Bae",
        "icon": "$(history)"
      },
      {
        "command": "sideBae.investigateIssue",
        "title": "Investigate Issue",
        "category": "Side Bae",
        "icon": "$(search-fuzzy)"
      },
      {
        "command": "sideBae.deleteTour",
        "title": "Delete Tour",
        "category": "Side Bae",
        "icon": "$(trash)"
      },
      {
        "command": "sideBae.startLesson",
        "title": "Learn from This Code",
        "category": "Side Bae",
        "icon": "$(mortar-board)"
      },
      {
        "command": "sideBae.scanLearnable",
        "title": "Scan for Things to Learn",
        "category": "Side Bae",
        "icon": "$(mortar-board)"
      }
    ],
    "keybindings": [
      {
        "command": "sideBae.previousNode",
        "key": "alt+left",
        "when": "sideBae.tourActive"
      },
      {
        "command": "sideBae.goForward",
        "key": "alt+right",
        "when": "sideBae.tourActive"
      },
      {
        "command": "sideBae.nextEdge",
        "key": "alt+down",
        "when": "sideBae.tourActive"
      },
      {
        "command": "sideBae.stopTour",
        "key": "escape",
        "when": "sideBae.tourActive && !editorHasSelection && !findInputFocussed && !inQuickOpen"
      },
      {
        "command": "sideBae.generateTour",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      },
      {
        "command": "sideBae.startLesson",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sideBae.refreshFeatures",
          "when": "view == sideBae.featureTree",
          "group": "navigation"
        },
        {
          "command": "sideBae.discoverFeatures",
          "when": "view == sideBae.featureTree",
          "group": "navigation"
        },
        {
          "command": "sideBae.whatsNew",
          "when": "view == sideBae.featureTree",
          "group": "navigation"
        },
        {
          "command": "sideBae.scanLearnable",
          "when": "view == sideBae.featureTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sideBae.deleteTour",
          "when": "viewItem == tour",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "sideBae.deleteTour",
          "when": "false"
        },
        {
          "command": "sideBae.nextEdge",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.previousNode",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.goForward",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.stopTour",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.openTour",
          "when": "false"
        },
        {
          "command": "sideBae.refreshFeatures",
          "when": "false"
        },
        {
          "command": "sideBae.discoverFeatures",
          "when": "false"
        },
        {
          "command": "sideBae.scanLearnable",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Side Bae",
      "properties": {
        "sideBae.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the Claude CLI binary. Leave empty to auto-detect. Set this if the extension can't find Claude (run `which claude` in your terminal to find the path)."
        },
        "sideBae.model": {
          "type": "string",
          "default": "haiku",
          "description": "Claude model for tour generation (haiku = fast, sonnet = balanced, opus = thorough)"
        },
        "sideBae.maxBudgetUsd": {
          "type": "number",
          "default": 0.5,
          "description": "Max cost (USD) per request"
        },
        "sideBae.celebrations": {
          "type": "string",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Follow system preference (respects Reduce Motion)",
            "Always show confetti and animations",
            "Never show confetti or animations"
          ],
          "description": "Control confetti and celebration animations"
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "sideBae.featureTree",
        "contents": "Open a folder to start exploring with Side Bae.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      },
      {
        "view": "sideBae.featureTree",
        "contents": "Explore this codebase with AI.\n[Ask About a Feature](command:sideBae.generateTour)\nAuto-detect what this codebase can do.\n[Discover All Features](command:sideBae.discoverFeatures)\nPaste a bug report, get root cause + fix.\n[Investigate an Issue](command:sideBae.investigateIssue)\nLive AI tutor teaches patterns from the code.\n[Learn from This Code](command:sideBae.startLesson)\nSee what changed in recent commits.\n[What's New](command:sideBae.whatsNew)",
        "when": "workbenchState != empty && !sideBae.hasTours && !sideBae.featuresLoaded"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "oxlint": "latest",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84"
  }
}
