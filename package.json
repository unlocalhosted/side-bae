{
  "name": "side-bae",
  "displayName": "Side Bae",
  "version": "1.3.0",
  "description": "AI-powered codebase onboarding via guided code tours",
  "publisher": "unlocalhosted",
  "license": "MIT",
  "icon": "media/icon.png",
  "keywords": [
    "codebase",
    "onboarding",
    "code tour",
    "AI",
    "walkthrough",
    "documentation",
    "learning"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/side-bae.git"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Education",
    "Visualization"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "side-bae",
          "title": "Side Bae",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "side-bae": [
        {
          "id": "sideBae.featureTree",
          "name": "Features",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "sideBae.exploreAtlas",
        "title": "Explore This Codebase",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.generateTour",
        "title": "Ask About a Feature",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.startTour",
        "title": "Start Saved Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.nextEdge",
        "title": "Follow Path",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.previousNode",
        "title": "Go Back",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.goForward",
        "title": "Go Forward",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.stopTour",
        "title": "Stop Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.refreshFeatures",
        "title": "Refresh Features",
        "category": "Side Bae",
        "icon": "$(refresh)"
      },
      {
        "command": "sideBae.discoverFeatures",
        "title": "Scan Codebase for Features",
        "category": "Side Bae",
        "icon": "$(search)"
      },
      {
        "command": "sideBae.openTour",
        "title": "Open Tour",
        "category": "Side Bae"
      },
      {
        "command": "sideBae.whatsNew",
        "title": "What's New",
        "category": "Side Bae",
        "icon": "$(history)"
      },
      {
        "command": "sideBae.investigateIssue",
        "title": "Investigate Issue",
        "category": "Side Bae",
        "icon": "$(search-fuzzy)"
      },
      {
        "command": "sideBae.deleteTour",
        "title": "Delete Tour",
        "category": "Side Bae",
        "icon": "$(trash)"
      },
      {
        "command": "sideBae.startLesson",
        "title": "Learn from This Code",
        "category": "Side Bae",
        "icon": "$(mortar-board)"
      },
      {
        "command": "sideBae.scanLearnable",
        "title": "Scan for Things to Learn",
        "category": "Side Bae",
        "icon": "$(mortar-board)"
      },
      {
        "command": "sideBae.startFullLesson",
        "title": "Start Pre-generated Lesson",
        "category": "Side Bae",
        "icon": "$(mortar-board)"
      },
      {
        "command": "sideBae.installSkillFiles",
        "title": "Install Skill Files for AI Agents",
        "category": "Side Bae",
        "icon": "$(cloud-download)"
      }
    ],
    "keybindings": [
      {
        "command": "sideBae.previousNode",
        "key": "alt+left",
        "when": "sideBae.tourActive"
      },
      {
        "command": "sideBae.goForward",
        "key": "alt+right",
        "when": "sideBae.tourActive"
      },
      {
        "command": "sideBae.nextEdge",
        "key": "alt+down",
        "when": "sideBae.tourActive"
      },
      {
        "command": "sideBae.stopTour",
        "key": "escape",
        "when": "sideBae.tourActive && !editorHasSelection && !findInputFocussed && !inQuickOpen"
      },
      {
        "command": "sideBae.generateTour",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      },
      {
        "command": "sideBae.startLesson",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "sideBae.exploreAtlas",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sideBae.discoverFeatures",
          "when": "view == sideBae.featureTree",
          "group": "navigation@1"
        },
        {
          "command": "sideBae.refreshFeatures",
          "when": "view == sideBae.featureTree",
          "group": "navigation@2"
        },
        {
          "command": "sideBae.investigateIssue",
          "when": "view == sideBae.featureTree",
          "group": "1_actions@1"
        },
        {
          "command": "sideBae.whatsNew",
          "when": "view == sideBae.featureTree",
          "group": "1_actions@2"
        },
        {
          "command": "sideBae.scanLearnable",
          "when": "view == sideBae.featureTree",
          "group": "1_actions@3"
        },
        {
          "command": "sideBae.startLesson",
          "when": "view == sideBae.featureTree",
          "group": "1_actions@4"
        }
      ],
      "view/item/context": [
        {
          "command": "sideBae.deleteTour",
          "when": "viewItem == tour",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "sideBae.deleteTour",
          "when": "false"
        },
        {
          "command": "sideBae.nextEdge",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.previousNode",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.goForward",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.stopTour",
          "when": "sideBae.tourActive"
        },
        {
          "command": "sideBae.openTour",
          "when": "false"
        },
        {
          "command": "sideBae.refreshFeatures",
          "when": "false"
        },
        {
          "command": "sideBae.discoverFeatures",
          "when": "false"
        },
        {
          "command": "sideBae.scanLearnable",
          "when": "false"
        },
        {
          "command": "sideBae.startFullLesson",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Side Bae",
      "properties": {
        "sideBae.provider": {
          "type": "string",
          "enum": [
            "auto",
            "claude-code",
            "copilot"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Auto-detect: try Copilot first, fall back to Claude Code",
            "Use Claude Code CLI (requires Claude subscription)",
            "Use GitHub Copilot (requires Copilot subscription)"
          ],
          "description": "AI backend for code analysis"
        },
        "sideBae.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the Claude CLI binary. Leave empty to auto-detect. Set this if the extension can't find Claude (run `which claude` in your terminal to find the path)."
        },
        "sideBae.model": {
          "type": "string",
          "default": "haiku",
          "description": "Claude model (haiku = fast, sonnet = balanced, opus = thorough)"
        },
        "sideBae.maxBudgetUsd": {
          "type": "number",
          "default": 0.5,
          "description": "Max cost (USD) per request"
        },
        "sideBae.celebrations": {
          "type": "string",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Follow system preference (respects Reduce Motion)",
            "Always show confetti and animations",
            "Never show confetti or animations"
          ],
          "description": "Control confetti and celebration animations"
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "sideBae.featureTree",
        "contents": "Open a folder to start exploring with Side Bae.\n[$(folder-opened) Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      },
      {
        "view": "sideBae.featureTree",
        "contents": "Get the big picture first — see how this codebase is organized, how data flows, and where to start.\n\n[$(globe) Explore This Codebase](command:sideBae.exploreAtlas)\n\nOr ask about something specific.\n\n[$(compass) Ask About a Feature](command:sideBae.generateTour)\n\nNo Claude or Copilot? Use skill files with any AI chat.\n\n[$(cloud-download) Install Skill Files](command:sideBae.installSkillFiles)",
        "when": "workbenchState != empty && !sideBae.hasContent"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "oxlint": "latest",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84"
  }
}
